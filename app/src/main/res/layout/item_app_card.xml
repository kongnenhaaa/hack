<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardBackgroundColor="@color/bg_card"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Top Header: ID & Name -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- ID Circle -->
            <FrameLayout
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_circle_blue">
                <TextView
                    android:id="@+id/tvAppInitial"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="7"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:layout_gravity="center"/>
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">
                
                <TextView
                    android:id="@+id/tvAppName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="7up"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:textSize="16sp"/>
                    
                <TextView
                    android:id="@+id/tvAppId"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ID: 3151270984274302494"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"/>
            </LinearLayout>

            <ImageView
                android:id="@+id/btnEditApp"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_menu_edit"
                app:tint="@color/text_secondary"
                android:layout_marginEnd="16dp"
                android:background="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"/>

            <ImageView
                android:id="@+id/btnDeleteApp"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_menu_delete"
                app:tint="@color/red_error"
                android:background="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#333333"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="12dp"/>

        <!-- ADB Commands Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ADB COMMANDS"
            android:textColor="@color/text_secondary"
            android:textSize="10sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_rounded_dark"
            android:padding="8dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">
            
            <TextView
                android:id="@+id/tvDeeplink"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="adb shell am start -a android.intent.action.VIEW..."
                android:textColor="@color/cyan_accent"
                android:textSize="12sp"
                android:fontFamily="monospace"/>
                
            <ImageView
                android:id="@+id/btnCopyCommand"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_menu_save"
                app:tint="@color/text_secondary"
                android:background="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>

        <!-- Trigger Button -->
        <Button
            android:id="@+id/btnTrigger"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="▶  TRIGGER"
            android:textColor="@color/black"
            android:textStyle="bold"
            android:backgroundTint="@color/cyan_accent"
            app:cornerRadius="8dp"
            android:layout_marginTop="8dp"/>
            
    </LinearLayout>
</androidx.cardview.widget.CardView>
