<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_dialog_map"
            app:tint="@color/cyan_accent" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Zalo Token"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="18sp"/>
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mini App Token Grabber"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"/>
        </LinearLayout>
        
        <TextView
            android:id="@+id/tvAppCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 apps"
            android:textColor="@color/cyan_accent"
            android:textStyle="bold"
            android:layout_marginEnd="16dp"/>
            
        <ImageView
            android:id="@+id/btnSettings"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/ic_menu_preferences"
            app:tint="@color/text_primary"/>
            
    </LinearLayout>

    <!-- Search & IP Bar -->
    <LinearLayout
        android:id="@+id/searchLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingBottom="12dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toBottomOf="@id/headerLayout">
        
        <EditText
            android:id="@+id/etSearch"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:background="@drawable/bg_rounded_dark"
            android:hint="Search mini apps..."
            android:textColorHint="@color/text_secondary"
            android:textColor="@color/white"
            android:paddingHorizontal="16dp"
            android:textSize="14sp"
            android:drawableStart="@android:drawable/ic_menu_search"
            android:drawablePadding="8dp"/>
            
        <TextView
            android:id="@+id/tvIpConfig"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="127.0.0.1:5000"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginStart="12dp"/>
    </LinearLayout>

    <!-- App List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvApps"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:paddingHorizontal="16dp"
        android:clipToPadding="false"
        android:paddingBottom="80dp"
        app:layout_constraintTop_toBottomOf="@id/searchLayout"
        app:layout_constraintBottom_toTopOf="@id/logContainer"/>

    <!-- Floating Action Button -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAdd"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:src="@android:drawable/ic_input_add"
        app:backgroundTint="@color/cyan_accent"
        app:tint="@color/bg_dark"
        app:layout_constraintBottom_toTopOf="@id/logContainer"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Bottom Log Console -->
    <LinearLayout
        android:id="@+id/logContainer"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:orientation="vertical"
        android:background="#0A0A0A"
        app:layout_constraintBottom_toBottomOf="parent">
        
        <!-- Log Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#111111"
            android:padding="8dp"
            android:gravity="center_vertical">
            
            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@android:drawable/ic_menu_sort_by_size"
                app:tint="@color/cyan_accent"/>
                
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="  HOOK LOG"
                android:textColor="@color/cyan_accent"
                android:textStyle="bold"
                android:textSize="12sp"/>
                
            <TextView
                android:id="@+id/tvLogStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="● WAITING"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:layout_marginEnd="12dp"/>
                
            <ImageView
                android:id="@+id/btnClearLog"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@android:drawable/ic_menu_delete"
                app:tint="@color/text_secondary"/>
        </LinearLayout>
        
        <!-- Log Content (Terminal Style) -->
        <ScrollView
            android:id="@+id/logScrollView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="8dp">
            
            <TextView
                android:id="@+id/tvTerminalLog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="10sp"
                android:fontFamily="monospace"
                android:text="> Xposed module initialized...\n> Waiting for Zalo process..."/>
                
        </ScrollView>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>